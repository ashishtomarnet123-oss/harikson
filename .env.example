# Neuravolt Cloud Environment Variables Template

# Node Environment
NODE_ENV=development
PORT=3000

# Databases
DATABASE_URL="postgresql://neuravolt:neuravolt_dev_pwd@localhost:5432/neuravolt?schema=public"
REDIS_URL="redis://localhost:6379"

# Authentication & Encryption Secrets
JWT_SECRET= # REQUIRED: Secure signing key (min 32 characters, no default)
TENANT_MASTER_KEY= # REQUIRED: Master document encryption key (min 32 characters, generate with openssl rand -base64 32)
PAYMENT_ENCRYPTION_KEY= # REQUIRED: Merchant credentials encryption key (min 32 characters)
NEXTAUTH_SECRET= # REQUIRED: Session encryption secret (no default)
ALLOWED_ORIGINS= # REQUIRED: Comma-separated list of allowed CORS origins (no default)

NEXTAUTH_URL="http://localhost:3001" # User Portal URL (app)
NEXTAUTH_ADMIN_URL="http://localhost:3002" # Admin Portal URL

# Web APIs & Gateways
NEXT_PUBLIC_API_URL="http://localhost:3000"
RESEND_API_KEY="re_dev_key_placeholder_value"
STRIPE_SECRET_KEY="sk_test_placeholder"
STRIPE_WEBHOOK_SECRET_FILE="./secrets/stripe_webhook_secret"
