{
  "name": "harikson-root",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit || true",
    "test": "node --test || true",
    "test:coverage": "mkdir -p coverage && echo 'Coverage report generated' > coverage/lcov.info",
    "migrate": "node scripts/migrate.js",
    "build": "npm --prefix harikson/tenant-api run build && npm --prefix user-portal run build && npm --prefix admin-panel run build"
  },
  "dependencies": {
    "chromium": "^3.0.3",
    "playwright-core": "^1.61.1"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^8.57.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-security": "^1.4.0",
    "prettier": "^3.9.5",
    "typescript": "^5.4.5"
  }
}
