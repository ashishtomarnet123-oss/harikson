# ==============================================================================
# Harikson AI Platform - One-VM Deployment Environment Variables Template
# ==============================================================================

# Core Service Configuration
PORT=3000
NODE_ENV=production
DOMAIN_NAME=localhost

# Security & Authentications (Will be randomly generated by deploy.sh if not set)
JWT_SECRET=GENERATED_JWT_SECRET
NEXTAUTH_SECRET=GENERATED_JWT_SECRET
ADMIN_SECRET=GENERATED_ADMIN_SECRET

# Database Connections
# Format: postgresql://[user]:[password]@[host]:[port]/[db_name]
POSTGRES_USER=neuravolt
POSTGRES_PASSWORD=GENERATED_DB_PASSWORD
POSTGRES_DB=neuravolt
DATABASE_URL=postgresql://neuravolt:GENERATED_DB_PASSWORD@postgres:5432/neuravolt

# Redis Connection URL
REDIS_URL=redis://redis:6379

# Ollama Engine URL
OLLAMA_HOST=http://ollama:11434

# Grafana Monitor Credentials
GRAFANA_ADMIN_PASSWORD=GENERATED_GRAFANA_PASSWORD
